<ContentPage
    x:Class="UserSignup.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Profile">

    <VerticalStackLayout
        Padding="30"
        Spacing="20">

        <Label
            Text="Signup Successful!"
            FontSize="28"
            FontAttributes="Bold"
            HorizontalOptions="Center"/>

        <Label
            Text="Username:"
            FontAttributes="Bold"/>

        <Label
            x:Name="UsernameLabel"/>

        <Label
            Text="Email:"
            FontAttributes="Bold"/>

        <Label
            x:Name="EmailLabel"/>

        <Button
            Text="Sign Out"
            Clicked="OnSignOutClicked"/>

    </VerticalStackLayout>

</ContentPage>